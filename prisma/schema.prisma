// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- USER & BUSINESS PROFILE (MERGED WITH AUTH) ---
model User {
  id              String    @id @default(uuid())
  
  // 🔐 NEW: Auth.js & Security Fields
  name            String?   // For NextAuth compatibility (Full Name)
  email           String    @unique
  emailVerified   DateTime? 
  password        String?   
  image           String?   // For Google/Facebook profile pics
  whatsapp        String?   
  accounts        Account[] // Relation for OAuth (Google, etc.)

  // 📦 EXISTING: Profile Data (Unchanged)
  isSetupComplete Boolean   @default(false)
  businessName    String?   // We will save 'storeName' from signup here!
  
  // 👇 YAHAN ADD KIYA HAI NAYA FIELD (To fix sidebar logic)
  businessType    String    @default("STOCK") // "STOCK" ya "SERVICE"
  
  ownerName       String?   
  city            String?
  
  // 📦 EXISTING: Expenses (Unchanged)
  monthlyRent     Float     @default(0.0)
  monthlySalaries Float     @default(0.0)
  monthlyHosting  Float     @default(0.0)
  monthlyInternet Float     @default(0.0)
  packagingCost   Float     @default(25.0)
  printingCost    Float     @default(0.0)
  
  // 📦 EXISTING: Settings (Unchanged)
  activeCouriers  String[]
  salesChannels   Json?
  courierRates    Json?     // To save localized custom rates

  // 🚀 UPDATED: SaaS Monetization (Gateway Agnostic)
  planType           String    @default("FREE") // 'FREE' or 'PRO'
  subscriptionId     String?   @unique          // External reference (e.g. MOCK_TXN_..., PayFast ID)
  subscriptionStatus String    @default("INACTIVE") // 'ACTIVE', 'PAST_DUE', 'CANCELED'
  paymentMethod      String?   // e.g. 'MOCK', 'PAYFAST', 'JAZZCASH'
  currentPeriodEnd   DateTime? // Expiry date

  // 📊 NEW: Usage Tracking for Free Tier Limits
  seoGensToday           Int       @default(0)
  reportsDownloadedToday Int       @default(0)
  totalPdfsDownloaded    Int       @default(0)
  lastPdfDownload        DateTime  @default(now())
  lastUsageReset         DateTime  @default(now()) // 👈 Added for daily reset tracking

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt // Added for NextAuth best practices
  
  // 📦 EXISTING: Relations (Unchanged)
  orders             Order[]
  products           Product[]
  services           Service[] // 👈 Yeh wapas add kiya hai
  expenses           Expense[]
  verificationLogs   VerificationLog[]
}

// ===================================================
// --- SERVICES (ADDED BACK) ---
// ===================================================
model Service {
  id            String   @id @default(uuid())
  name          String
  price         Float    @default(0.0) // Kept for backward compatibility if needed
  description   String?  // Naya field
  productionCost Float   @default(0.0) // Naya field
  sellingPrice   Float   @default(0.0) // Naya field
  estimatedTime  String? @default("3-5 Days") // Naya field
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  orders        Order[]  // 👈 Yeh line zaroori hai order relation ke liye
}

// ===================================================
// --- WHATSAPP VERIFICATION LOGS (MINIMAL) ---
// ===================================================

enum VerificationAction {
  CONFIRMED
  RECHECKED
  BLOCKED
}

model VerificationLog {
  id           String             @id @default(uuid())
  phoneNumber  String
  riskScore    Int
  actionTaken  VerificationAction
  createdAt    DateTime           @default(now())

  userId       String
  user         User               @relation(fields: [userId], references: [id])

  @@index([phoneNumber])
  @@index([userId])
}

// 🔐 NEW: NEXTAUTH MODELS (For Google/Facebook Login)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// 🔐 NEW: SECURITY MODELS
model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// Rate Limiting to prevent Brute Force Attacks
model RateLimit {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  attempts  Int      @default(1)
  lastTry   DateTime @default(now())
  locked    Boolean  @default(false)

  @@unique([email])
}


// ===================================================
// --- INVENTORY SYSTEM (PART 2 - 100% UNCHANGED) ---
// ===================================================

model Product {
  id            String       @id @default(uuid())
  name          String
  sku           String?
  category      String?
  
  currentStock  Int          @default(0)
  averageCost   Float        @default(0.0) 
  sellingPrice  Float        @default(0.0)
  
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  batches       StockBatch[]
  orders        Order[]
}

model StockBatch {
  id            String   @id @default(uuid())
  batchName     String   
  supplier      String?
  
  initialQty    Int
  remainingQty  Int
  
  totalCost     Float    
  costPerItem   Float    
  
  dateAdded     DateTime @default(now())
  
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
}

// ===================================================
// --- ORDERS & EXPENSES ---
// ===================================================

model Order {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  customerName    String
  city            String
  salePrice       Float
  
  productCost     Float    
  shippingCost    Float
  packagingCost   Float
  fixedCostShare  Float
  
  status          String   @default("PENDING")
  netProfit       Float
  
  quantity        Int      @default(1)
  paymentMethod   String   @default("COD")
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  // Product Relation
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  
  // 👇 NAYA: Service Relation
  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}